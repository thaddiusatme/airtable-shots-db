{
  "manifest_version": 3,
  "name": "YouTube Transcript → Airtable",
  "version": "1.0.0",
  "description": "Extract YouTube transcripts and save them to Airtable",
  "permissions": [
    "activeTab",
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://api.airtable.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
