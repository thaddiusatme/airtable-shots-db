# --- Required ---
# Absolute path to the yt-frame-poc repo
YT_FRAME_POC_PATH=/Users/you/repos/yt-frame-poc

# Airtable credentials (also read from ../.env)
# AIRTABLE_API_KEY=patXXXXXXXXXXXXXX
# AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# --- Optional ---
# Server port (default: 3333)
# PIPELINE_PORT=3333

# R2 credentials are read from ../.env automatically
